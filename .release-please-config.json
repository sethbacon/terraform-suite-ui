        },
        {
          "type": "fix",
          "section": "Bug Fixes"
        },
        {
          "type": "perf",
          "section": "Performance"
        },
        {
          "type": "deps",
          "section": "Dependencies"
        },
        {
          "type": "docs",
          "section": "Documentation"
        },
        {
          "type": "refactor",
          "section": "Refactor"
        },
        {
          "type": "revert",
          "section": "Reverts"
        },
        {
          "type": "security",
          "section": "Security"
        }
      ]
    }
  }
}